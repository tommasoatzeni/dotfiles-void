# Apri video YouTube con mpv
browser "mpv %u &"
macro v set browser "mpv %u &" ; open-in-browser ; set browser "mpv %u &"

# Aggiornamento automatico ogni ora
auto-reload yes
reload-time 60
max-items 100

# Nascondi feed già letti
#show-read-feeds no

# Conferma uscita
confirm-exit yes

# Ordinamento per data
feed-sort-order date-desc
